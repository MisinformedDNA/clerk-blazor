@page "/login"

@inject ClerkAuthService ClerkAuth
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>Sign in</PageTitle>

<h1>Sign in</h1>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}

@if (_signingIn)
{
    <p>Opening sign-in…</p>
}
else
{
    <p>Click the button below to sign in with Clerk.</p>
    <button class="btn btn-primary" @onclick="HandleSignIn" disabled="@_signingIn">
        Sign in with Clerk
    </button>
}

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private bool _signingIn;
    private string? _errorMessage;

    private async Task HandleSignIn()
    {
        _signingIn = true;
        _errorMessage = null;

        try
        {
            // Open the Clerk hosted sign-in modal.
            // The method returns after the user closes the modal.
            await ClerkAuth.SignInAsync();

            // Ask the provider to re-check the current session.
            if (AuthProvider is ClerkAuthenticationStateProvider clerkProvider)
                await clerkProvider.ForceRefreshAsync();

            // Prefer Clerk user state directly, then fall back to auth state.
            var user = await ClerkAuth.GetUserAsync();
            if (user is not null)
            {
                Nav.NavigateTo(GetPostLoginDestination());
                return;
            }

            var authState = await AuthProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
                Nav.NavigateTo(GetPostLoginDestination());
        }
        catch (Exception ex)
        {
            _errorMessage = $"Sign-in failed: {ex.Message}";
        }
        finally
        {
            _signingIn = false;
        }
    }

    private string GetPostLoginDestination()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
            return "/";

        var baseUri = Nav.ToAbsoluteUri(Nav.BaseUri);

        // RedirectToLogin passes an absolute URL. Allow only same-origin values.
        if (Uri.TryCreate(ReturnUrl, UriKind.Absolute, out var absoluteUri))
        {
            if (absoluteUri.Scheme == baseUri.Scheme &&
                absoluteUri.Host == baseUri.Host &&
                absoluteUri.Port == baseUri.Port)
            {
                return absoluteUri.PathAndQuery + absoluteUri.Fragment;
            }

            return "/";
        }

        // Also support relative paths.
        if (ReturnUrl.StartsWith('/'))
            return ReturnUrl;

        return $"/{ReturnUrl}";
    }
}
